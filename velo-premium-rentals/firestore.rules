rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      // Allow full access based on your app's hardcoded admin email
      return request.auth != null && (request.auth.token.email == 'ken@velorentals.com' || request.auth.token.email == 'velocarrentals@gmail.com');
    }

    match /cars/{carId} {
      // Anyone can read the cars collection
      allow read: if true;
      
      // Only admins can write to cars collection
      allow write: if isAdmin();
    }

    match /bookings/{bookingId} {
      // Users need to read all bookings to check for booking clashes when creating a new one
      allow read: if request.auth != null;
      
      // Any authenticated user can create a booking for themselves
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      allow update: if request.auth != null && (
        isAdmin() ||
        (
          resource.data.userId == request.auth.uid &&
          (
            request.resource.data.status == 'cancelled' ||
            request.resource.data.status == 'pending_verification'
          )
        )
      );
      
      allow delete: if request.auth != null && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    match /chat_sessions/{sessionId} {
      allow read: if isAdmin() || 
                  (request.auth != null && request.auth.uid == sessionId) || 
                  (resource != null && resource.data.userId == "anonymous") || 
                  (request.auth != null && resource != null && resource.data.userId == request.auth.uid);
                  
      allow create: if true;
      
      allow update: if isAdmin() || 
                    (request.auth != null && request.auth.uid == sessionId) || 
                    (resource != null && resource.data.userId == "anonymous") || 
                    (request.auth != null && resource != null && resource.data.userId == request.auth.uid);
                    
      allow delete: if isAdmin();
      
      match /messages/{messageId} {
        allow read, create: if isAdmin() || 
                            (request.auth != null && request.auth.uid == sessionId) || 
                            get(/databases/$(database)/documents/chat_sessions/$(sessionId)).data.userId == "anonymous" ||
                            (request.auth != null && get(/databases/$(database)/documents/chat_sessions/$(sessionId)).data.userId == request.auth.uid);
                            
        allow update, delete: if isAdmin();
      }
    }
  }
}
